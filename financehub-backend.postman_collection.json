    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/analytics/dashboard-summary?startDate={{startDate}}&endDate={{endDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analytics", "dashboard-summary"],
              "query": [
                { "key": "startDate", "value": "{{startDate}}" },
                { "key": "endDate", "value": "{{endDate}}" }
              ]
            }
          }
        },
        {
          "name": "Account Reconciliation",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/analytics/account-reconciliation?bankAccountId={{bankAccountId}}&startDate={{startDate}}&endDate={{endDate}}&referenceBalance={{referenceBalance}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analytics", "account-reconciliation"],
              "query": [
                { "key": "bankAccountId", "value": "{{bankAccountId}}" },
                { "key": "startDate", "value": "{{startDate}}" },
                { "key": "endDate", "value": "{{endDate}}" },
                { "key": "referenceBalance", "value": "{{referenceBalance}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Governance",
      "item": [
        {
          "name": "List Audit Events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/governance/audit-events"
          }
        },
        {
          "name": "List Trash Items",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/governance/trash-items"
          }
        },
        {
          "name": "Restore Trash Item",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/governance/trash-items/{{trashId}}/restore"
          }
        },
        {
          "name": "Purge Trash Item",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/governance/trash-items/{{trashId}}"
          }
        },
        {
          "name": "Get Retention Settings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/governance/retention-settings"
          }
        },
        {
          "name": "Update Retention Settings",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trashRetentionDays\": 30,\n  \"auditRetentionDays\": 180\n}"
            },
            "url": "{{baseUrl}}/api/v1/governance/retention-settings"
          }
        },
        {
          "name": "Get App Preferences",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/governance/app-preferences"
          }
        },
        {
          "name": "Update App Preferences",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"defaultBillCategory\": \"Moradia\",\n  \"defaultBillRecurring\": false,\n  \"defaultBillDueDay\": 5,\n  \"defaultIncomeCategory\": \"Trabalho\",\n  \"defaultIncomeRecurring\": false,\n  \"defaultIncomeReceivedDay\": 1,\n  \"defaultDashboardMode\": \"month\",\n  \"defaultDashboardMonthComparisonOffset\": 1,\n  \"billCategories\": [\"Moradia\", \"Alimentacao\", \"Utilidades\", \"Saude\", \"Transporte\", \"Educacao\", \"Lazer\", \"Outros\"],\n  \"incomeCategories\": [\"Trabalho\", \"Extra\", \"Investimentos\", \"Reembolso\", \"Outros\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/governance/app-preferences"
          }
        },
        {
          "name": "Run Retention Cleanup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/governance/retention-cleanup"
          }
        },
        {
          "name": "Emergency Reset All Data",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/governance/emergency-reset"
          }
        }
      ]
    },
    {
      "name": "Statements",
      "item": [
        {
          "name": "Import OFX",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "ownerName", "type": "text", "value": "{{ownerName}}" },
                { "key": "ownerCpf", "type": "text", "value": "{{ownerCpf}}" },
                { "key": "applyInternalTransferDetection", "type": "text", "value": "true" }
              ]
            },
            "url": "{{baseUrl}}/api/v1/statements/import/ofx"
          }
        },
        {
          "name": "Export OFX",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/statements/export/ofx?startDate={{startDate}}&endDate={{endDate}}&bankOrg=Finance%20Hub&fid=999&bankId=9999&branchId=0001&accountId=000000-0&currency=BRL",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "statements", "export", "ofx"],
              "query": [
                { "key": "startDate", "value": "{{startDate}}" },
                { "key": "endDate", "value": "{{endDate}}" },
                { "key": "bankOrg", "value": "Finance Hub" },
                { "key": "fid", "value": "999" },
                { "key": "bankId", "value": "9999" },
                { "key": "branchId", "value": "0001" },
                { "key": "accountId", "value": "000000-0" },
                { "key": "currency", "value": "BRL" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Transfers",
      "item": [
        {
          "name": "Link Internal Transfer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"billId\": \"{{billId}}\",\n  \"incomeId\": \"{{incomeId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/transfers/internal/link"
          }
        },
        {
          "name": "Detect Internal Transfers",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerName\": \"{{ownerName}}\",\n  \"ownerCpf\": \"{{ownerCpf}}\",\n  \"dateToleranceDays\": 1,\n  \"autoApply\": true\n}"
            },
            "url": "{{baseUrl}}/api/v1/transfers/internal/detect"
          }
        }
      ]
    },
