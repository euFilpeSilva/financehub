{
  "info": {
    "name": "FinanceHub Backend API",
    "description": "Collection com todos os endpoints do backend FinanceHub.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Bills",
      "item": [
        {
          "name": "List Bills",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/bills"
          }
        },
        {
          "name": "Create Bill",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Conta de energia\",\n  \"category\": \"Utilidades\",\n  \"amount\": 180.5,\n  \"dueDate\": \"2026-03-10\",\n  \"recurring\": false,\n  \"paid\": false,\n  \"internalTransfer\": false,\n  \"bankAccountId\": null\n}"
            },
            "url": "{{baseUrl}}/api/v1/bills"
          }
        },
        {
          "name": "Update Bill",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Conta de energia (ajustada)\",\n  \"category\": \"Utilidades\",\n  \"amount\": 190.0,\n  \"dueDate\": \"2026-03-10\",\n  \"recurring\": false,\n  \"paid\": true,\n  \"internalTransfer\": false,\n  \"bankAccountId\": null\n}"
            },
            "url": "{{baseUrl}}/api/v1/bills/{{billId}}"
          }
        },
        {
          "name": "Delete Bill",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/bills/{{billId}}"
          }
        },
        {
          "name": "Create Recurring Bills",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/bills/recurring?month={{selectedMonth}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bills", "recurring"],
              "query": [{ "key": "month", "value": "{{selectedMonth}}" }]
            }
          }
        }
      ]
    },
